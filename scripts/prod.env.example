# Copy to scripts/prod.env and fill in. scripts/prod.env is gitignored —
# NEVER commit real server details; this repository is public.

# Base URL of the running JackedLog server (no trailing slash).
JACKED_URL=https://jackedlog.example.com

# API key the server was started with (JACKED_API_KEY on the host).
JACKED_API_KEY=changeme

# Optional: SSH host for prod-logs / prod-restart (user@host).
JACKED_SSH_HOST=

# Optional: directory on the host containing docker-compose.yml.
JACKED_COMPOSE_DIR=/opt/jackedlog
